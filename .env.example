# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Token del bot obtenido de @BotFather
TELEGRAM_TOKEN=123456:AAxx...

# ID del grupo de Telegram (numero negativo)
# Para obtenerlo: envia un mensaje al grupo y visita
# https://api.telegram.org/bot<TOKEN>/getUpdates
# Busca "chat" -> "id"
CHAT_ID=-1001234567890

# ── AEMET ─────────────────────────────────────────────────────────────────────
# Clave API gratuita — obtener en https://opendata.aemet.es
AEMET_API_KEY=eyJhbGci...

# Codigo INE de provincia (11=Cadiz, 41=Sevilla, 50=Zaragoza...)
PROVINCIA_CODIGO=11

# Codigo INE de municipio para la prediccion horaria
# Busca el tuyo en: https://www.aemet.es/xml/municipios/localidad_XXXXX.xml
MUNICIPIO_CODIGO=11012

# ── CAP alertas oficiales ─────────────────────────────────────────────────────
# Codigo del area CAP de AEMET segun comunidad autonoma:
# 61=Andalucia occidental  62=Andalucia oriental  63=Aragon
# 64=Asturias  65=Cantabria  66=Castilla-La Mancha  67=Castilla y Leon
# 68=Cataluna  69=Extremadura  70=Galicia  71=Baleares
# 72=La Rioja  73=Madrid  74=Murcia  75=Navarra  76=Pais Vasco
# 77=Valencia  78=Canarias  79=Ceuta y Melilla
CAP_AREA=61

# Prefijo de zona CAP — primeros dos digitos despues del codigo de area
# En Andalucia coincide con el codigo INE de provincia (11=Cadiz, 41=Sevilla...)
# En Aragon NO coincide: Zaragoza=33, Huesca=22, Teruel=44
# Si no sabes el valor dejalo vacio y se usara PROVINCIA_CODIGO
CAP_ZONA_PREFIJO=11

# ── Telethon ──────────────────────────────────────────────────────────────────
# Obtener API_ID y API_HASH en https://my.telegram.org
TELETHON_API_ID=12345678
TELETHON_API_HASH=abcdef1234567890abcdef1234567890
# Numero de telefono de la cuenta que envia los mensajes (+34...)
TELETHON_PHONE=+34600000000

# ── Destinatarios por nivel (numeros separados por coma, con codigo de pais) ──
TEL_DEFAULT=+34600000001
TEL_CAPATACES=+34600000002,+34600000003
TEL_JEFES_UNIDAD=+34600000004,+34600000005
TEL_JEFE_COEX=+34600000006

# ── URLs de recomendaciones (pendiente BBDD) ──────────────────────────────────
URL_TEMP_I=
URL_TEMP_II=
URL_TEMP_III=
URL_TEMP_IV=
URL_TEMP_V=

URL_PRECIP_I=
URL_PRECIP_II=
URL_PRECIP_III=
URL_PRECIP_IV=
URL_PRECIP_V=

URL_VIENTO_I=
URL_VIENTO_II=
URL_VIENTO_III=
URL_VIENTO_IV=
URL_VIENTO_V=
